     1                                  ;assembly hello! in 32 bit system
     2                                  SECTION .text:	; text means it's the code section
     3                                  
     4                                  GLOBAL _start	; we mark it as global so now it will be visible to the whole program
     5                                  
     6                                  _start:	; it's the Entry point
     7 00000000 B804000000              	mov eax, 0x4	; system call for write
     8 00000005 BB01000000              	mov ebx, 1	; output on console
     9 0000000A B9[00000000]            	mov ecx, message	; The string which we want to write on console
    10 0000000F BA08000000              	mov edx, message_length		; Length of the string
    11 00000014 CD80                    	int 0x80	; Invoke system call
    12                                  
    13                                  	; Exiting program
    14 00000016 B801000000               	mov eax, 0x1	; Exit system call
    15 0000001B BB00000000              	mov ebx, 0	; return zero (optional)
    16 00000020 CD80                    	int 0x80	; Invoke system call
    17                                  
    18                                  SECTION .data:	
    19 00000000 68656C6C6F210A00        	message: db "hello!", 0xA, 0x0
    20                                  	message_length: equ $-message	; $-> means current address so Current address - message gives as the string lenght
    21                                  	
